# Runtime storage
PREFLIGHT_UPLOAD_DIR=uploads
PREFLIGHT_DB_PATH=data/preflight.sqlite3

# Upload limits
PREFLIGHT_MAX_FILE_SIZE_MB=25

# Optional local AI suggestions
PREFLIGHT_LLM_PROVIDER=auto
PREFLIGHT_OLLAMA_MODEL=mistral
PREFLIGHT_OLLAMA_BASE_URL=http://localhost:11434

# Optional Groq-hosted AI suggestions
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
